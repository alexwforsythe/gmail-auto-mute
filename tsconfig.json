{
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["ESNext"],
    "target": "esnext",
    "module": "esnext",
    "types": ["bun", "google-apps-script"],

    "moduleResolution": "bundler",
    "noEmit": true,

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src", "build.ts"]
}
